{
  "invoice_number": "(?i)(?:invoice|inv)(?:\\s*(?:no\\.?|#|number))?[:.\\s]*([A-Z0-9][A-Z0-9-]{3,30})",
  "date": "(?i)(?:invoice\\s*date|bill\\s*date|dated?)[:.\\s]*([0-9]{1,2}[-/][0-9]{1,2}[-/][0-9]{2,4}|[0-9]{4}[-/][0-9]{1,2}[-/][0-9]{1,2})",
  "vendor_name": "(?i)(?:vendor|supplier|sold\\s*by|from)[:.\\s]*([A-Za-z0-9&.,'\\-\\s]{3,80})",
  "total_amount": "(?i)(?:grand\\s*total|total\\s*amount|amount\\s*payable|net\\s*payable)[:.\\s]*(?:[₹$€£]\\s*)?([0-9]+(?:[.,][0-9]{2})?|[0-9]{1,3}(?:,[0-9]{3})*(?:\\.[0-9]{2})?)",
  "gst_number": "(?i)(?:gst(?:in)?|gst\\s*no\\.?)[:.\\s]*([0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1})",
  "due_date": "(?i)(?:due\\s*date|pay\\s*by|payment\\s*due)[:.\\s]*([0-9]{1,2}[-/][0-9]{1,2}[-/][0-9]{2,4}|[0-9]{4}[-/][0-9]{1,2}[-/][0-9]{1,2})"
}
