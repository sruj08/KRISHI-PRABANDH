  "lesion_type": "(?i)lesion\\s*type[:.\\s]*([A-Za-z0-9 ,./+\\-]{2,80})",
  "stent": "(?i)(?:stent|stent\\s*type)[:.\\s]*([A-Za-z0-9 ,./+\\-×x\\d]{2,120})",
